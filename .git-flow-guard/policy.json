{
  "branch_from": [
    {
      "source": "main",
      "source_ref": "refs/heads/main",
      "target": "dev",
      "target_ref": "refs/heads/dev",
      "target_ref_regex": "^refs/heads/dev$"
    },
    {
      "source": "dev",
      "source_ref": "refs/heads/dev",
      "target": "release/*",
      "target_ref": "refs/heads/release/*",
      "target_ref_regex": "^refs/heads/release/.+$"
    }
  ],
  "branches": {
    "families": [
      "release/*"
    ],
    "long_lived": [
      "main",
      "dev"
    ]
  },
  "direct_commit_refs": [
    {
      "name": "dev",
      "ref": "refs/heads/dev",
      "ref_regex": "^refs/heads/dev$"
    },
    {
      "name": "release/*",
      "ref": "refs/heads/release/*",
      "ref_regex": "^refs/heads/release/.+$"
    }
  ],
  "merge_rules": [
    {
      "id": "release/* to dev",
      "source": "release/*",
      "source_ref": "refs/heads/release/*",
      "source_ref_regex": "^refs/heads/release/.+$",
      "target": "dev",
      "target_ref": "refs/heads/dev"
    },
    {
      "id": "release/* to main",
      "source": "release/*",
      "source_ref": "refs/heads/release/*",
      "source_ref_regex": "^refs/heads/release/.+$",
      "tag_pattern": "V#.#",
      "tag_ref": "refs/tags/V#.#",
      "tag_ref_regex": "^refs/tags/V[0-9]+\\.[0-9]+$",
      "tag_tokens": [
        "#",
        "#"
      ],
      "target": "main",
      "target_ref": "refs/heads/main"
    }
  ],
  "protected_refs": [
    "refs/heads/dev",
    "refs/heads/main"
  ],
  "required_targets": [
    {
      "source": "release/*",
      "source_ref": "refs/heads/release/*",
      "source_ref_regex": "^refs/heads/release/.+$",
      "target_refs": [
        "refs/heads/dev",
        "refs/heads/main"
      ],
      "targets": [
        "dev",
        "main"
      ]
    }
  ],
  "source": {
    "file": "contribution.md",
    "format": "mermaid.gitGraph",
    "path": ".git-flow-guard/contribution.md"
  },
  "tag_rules": [
    {
      "source": "release/*",
      "tag_pattern": "V#.#",
      "tag_ref": "refs/tags/V#.#",
      "tag_ref_regex": "^refs/tags/V[0-9]+\\.[0-9]+$",
      "tag_tokens": [
        "#",
        "#"
      ],
      "target": "main"
    }
  ],
  "version": 1
}